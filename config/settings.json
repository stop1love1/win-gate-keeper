{
    "BasePath": "C:\\WinGateKeeper",
    "UsersRoot": "C:\\WinGateKeeper\\Users",
    "LogsPath": "C:\\WinGateKeeper\\Logs",
    "SSHConfigPath": "C:\\ProgramData\\ssh\\sshd_config",
    "SFTPOnlyGroup": "SFTPUsers",
    "SSHPort": 22,
    "SSHSecurity": {
        "MaxAuthTries": 3,
        "MaxStartups": "3:50:10",
        "ClientAliveInterval": 300,
        "ClientAliveCountMax": 2,
        "LoginBanner": true,
        "BannerPath": "C:\\ProgramData\\ssh\\banner.txt",
        "AllowedIPs": "*"
    },
    "LogManagement": {
        "MaxLogAgeDays": 90
    },
    "PowerShellLogging": {
        "TranscriptionPath": "C:\\WinGateKeeper\\Logs\\Transcripts"
    },
    "HyperV": {
        "DefaultVMPath": "C:\\HyperV\\VMs",
        "DefaultVHDPath": "C:\\HyperV\\VHDs",
        "DefaultBackupPath": "C:\\HyperV\\Backups",
        "DefaultSwitchName": "Default Switch",
        "DefaultRAMGB": 2,
        "DefaultCPUCount": 2,
        "DefaultDiskSizeGB": 50,
        "DefaultGeneration": 2,
        "CheckpointRetention": {
            "MaxAgeDays": 30,
            "MaxPerVM": 5
        }
    }
}
